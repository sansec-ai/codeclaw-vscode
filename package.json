{
  "name": "codeclaw-vscode",
  "displayName": "Code Claw - OpenClaw VSCode",
  "description": "Turn WeChat into a remote Claude Code terminal. Chat with AI from your phone via ClawBot. Part of the OpenClaw ecosystem.",
  "version": "0.1.79",
  "publisher": "Sansec",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sansec-ai/codeclaw-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onCommand:codeClaw.connect",
    "onCommand:codeClaw.disconnect",
    "onCommand:codeClaw.showPanel",
    "onView:wechatVscodeSidebar"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "package": "npm run vscode:prepublish && npx @vscode/vsce package --allow-missing-repository",
    "test": "npm run compile && node --test tests/*.test.js",
    "test:fast": "npm run compile && SKIP_SLOW_TESTS=1 node --test tests/*.test.js",
    "test:e2e": "npm_config_proxy=http://127.0.0.1:7897 npm_config_https_proxy=http://127.0.0.1:7897 npx vscode-test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "mocha": "^11.7.5",
    "typescript": "^5.7.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "openclaw",
    "wechat",
    "claude",
    "claude-code",
    "clawbot",
    "ai-coding",
    "remote-coding",
    "mobile-coding",
    "phone-coding",
    "vscode-extension"
  ],
  "contributes": {
    "configuration": {
      "title": "Code Claw",
      "properties": {
        "codeClaw.environmentVariables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "环境变量名"
              },
              "value": {
                "type": "string",
                "description": "环境变量值"
              }
            },
            "required": [
              "name",
              "value"
            ]
          },
          "default": [],
          "description": "传递给 Claude CLI 的环境变量，格式与 claudeCode.environmentVariables 相同。配置了哪些就加载哪些，未配置的变量会自动从 claudeCode.environmentVariables 回退读取。",
          "order": 2
        },
        "codeClaw.logLevel": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ],
          "enumDescriptions": {
            "DEBUG": "输出所有日志，包含详细的调试信息",
            "INFO": "输出常规信息（默认）",
            "WARN": "仅输出警告和错误",
            "ERROR": "仅输出错误"
          },
          "default": "INFO",
          "description": "插件日志级别，控制输出通道中的日志详细程度。",
          "order": 1
        },
        "codeClaw.streaming": {
          "type": "boolean",
          "default": true,
          "description": "是否将 Claude Code 的中间过程（工具调用、思考等）实时发送到微信。关闭后仅发送最终结果。",
          "order": 3
        },
        "codeClaw.telegramApiBaseUrl": {
          "type": "string",
          "default": "https://api.telegram.org",
          "description": "Telegram Bot API 地址（默认为官方地址，测试时可指向本地 mock 服务器）。",
          "order": 4
        },
        "codeClaw.telegramPollTimeout": {
          "type": "number",
          "default": 30,
          "description": "Telegram long-poll 超时秒数（测试时可设为较小的值如 2）。",
          "order": 5
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeClaw-sidebar",
          "title": "WeChat",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "codeClaw-sidebar": [
        {
          "type": "webview",
          "id": "codeClawVscodeSidebar",
          "name": "Code Claw"
        }
      ]
    },
    "commands": [
      {
        "command": "codeClaw.connect",
        "title": "连接微信",
        "category": "WeChat",
        "icon": "$(plug)"
      },
      {
        "command": "codeClaw.disconnect",
        "title": "断开连接",
        "category": "WeChat",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "codeClaw.showPanel",
        "title": "显示面板",
        "category": "WeChat"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codeClaw.connect",
          "when": "view == wechatVscodeSidebar",
          "group": "navigation",
          "icon": "$(plug)"
        },
        {
          "command": "codeClaw.disconnect",
          "when": "view == wechatVscodeSidebar",
          "group": "navigation",
          "icon": "$(debug-disconnect)"
        }
      ]
    }
  }
}