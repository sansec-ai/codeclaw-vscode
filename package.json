{
  "name": "wechat-vscode",
  "displayName": "WeChat Claude Code",
  "description": "通过微信控制 VSCode 项目 - 使用 Claude Code 处理微信消息",
  "version": "0.1.0",
  "publisher": "wechat-vscode",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "wechat",
    "claude",
    "claude-code",
    "bridge",
    "chat"
  ],
  "contributes": {
    "commands": [
      {
        "command": "wechat-vscode.connect",
        "title": "WeChat: 连接微信",
        "category": "WeChat"
      },
      {
        "command": "wechat-vscode.disconnect",
        "title": "WeChat: 断开连接",
        "category": "WeChat"
      },
      {
        "command": "wechat-vscode.showPanel",
        "title": "WeChat: 显示面板",
        "category": "WeChat"
      }
    ]
  }
}
